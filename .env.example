# Create this key in Google Cloud Console.
# Enable Maps JavaScript API.
# Attach an active billing account, even when using free trial credit.
# Add HTTP referrer restrictions:
# http://localhost:5173/*
# http://127.0.0.1:5173/*
# For LAN multiplayer, also add your shown LAN URL, for example:
# http://192.168.1.42:5173/*
VITE_GOOGLE_MAPS_API_KEY=replace_with_your_google_maps_javascript_api_key
VITE_ENABLE_DEBUG_TOOLS=false

# Optional. The app usually derives this from the current hostname.
# VITE_MULTIPLAYER_SERVER_URL=http://192.168.1.42:3001
